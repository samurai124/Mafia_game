<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mafia Party Game</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>

<!-- Phase Transition Overlay -->
<div id="phase-overlay" class="phase-overlay">
  <div class="overlay-text" id="overlay-text"></div>
</div>

<div class="layout-wrapper">
  <div class="app-container">

  <!-- ── Landing ── -->
  <section id="landing-screen" class="screen active">
    <div class="logo-area">
      <div class="logo-icon">🕵️‍♂️</div>
      <h1 class="game-title">Mafia</h1>
    </div>
    <div class="win-stats" id="landing-stats" style="display:none">
      <div class="stat-box"><div class="stat-num" id="stat-wins">0</div><div class="stat-label">Wins</div></div>
      <div class="stat-box"><div class="stat-num" id="stat-games">0</div><div class="stat-label">Games</div></div>
      <div class="stat-box"><div class="stat-num" id="stat-winrate">0%</div><div class="stat-label">Win Rate</div></div>
    </div>
    <div class="input-group">
      <label>Your Name</label>
      <input type="text" id="player-name" placeholder="Enter your name" maxlength="20" autocomplete="off">
    </div>
    <button id="btn-create" class="btn">Create New Room</button>
    <div class="divider">or join existing</div>
    <div class="input-group">
      <label>Room Code</label>
      <input type="text" id="room-code-input" placeholder="e.g. ABC123" maxlength="6" autocomplete="off" style="text-transform:uppercase">
    </div>
    <button id="btn-join" class="btn btn-secondary">Join Game</button>
    <p id="error-msg" class="error-msg hidden"></p>
  </section>

  <!-- ── Waiting Room ── -->
  <section id="waiting-screen" class="screen text-center">
    <span class="phase-badge badge-blue">Lobby</span>
    <h2>Waiting Room</h2>
    <div class="room-code-box">
      <div>
        <span class="room-code-label">Room Code</span>
        <span id="display-room-code" class="room-code-value">------</span>
      </div>
      <button id="btn-copy-code" class="btn-icon" title="Copy code">📋</button>
    </div>
    <p style="color:var(--text-secondary);font-size:1.1rem;margin-bottom:24px;font-weight:500">
      <strong id="player-count-num" style="color:var(--text-primary)">0</strong> players connected
    </p>
    <ul id="player-list" class="player-list"></ul>

    <!-- Host settings -->
    <div id="host-controls" class="hidden">
      <div id="settings-panel" class="settings-panel hidden">
        <h3>⚙️ Game Settings</h3>
        <div class="setting-row"><label>Discussion Time (s)</label><input type="number" id="set-discussion" min="30" max="600" value="120"></div>
        <div class="setting-row"><label>Voting Time (s)</label><input type="number" id="set-voting" min="15" max="120" value="30"></div>
        <div class="setting-row"><label>Defense Time (s)</label><input type="number" id="set-defense" min="10" max="120" value="30"></div>
        <div class="setting-row"><label>Enable Defense Phase</label><input type="checkbox" id="set-enableDefense" checked></div>
        <div class="setting-row"><label>Enable Last Words</label><input type="checkbox" id="set-enableLastWords" checked></div>
        <div class="setting-row"><label>Enable Cheikh Role</label><input type="checkbox" id="set-enableCheikh" checked></div>
      </div>
      <button id="btn-toggle-settings" class="btn btn-secondary" style="max-width:220px;margin-bottom:12px">⚙️ Settings</button>
      <p style="font-size:0.9rem;color:var(--text-muted);margin-bottom:16px;font-weight:600">Requires 4+ players to start</p>
      <button id="btn-start" class="btn btn-lg" disabled>Start Game</button>
    </div>
    <p id="waiting-note" style="color:var(--text-muted);font-size:1.1rem;font-weight:500">Waiting for host to start the game...</p>
  </section>

  <!-- ── Role ── -->
  <section id="role-screen" class="screen text-center">
    <span class="phase-badge badge-purple">Role Reveal</span>
    <h2>Your Identity</h2>
    <div id="role-card-container" class="role-card-large">
      <div id="role-emoji" class="role-emoji-large">❓</div>
      <div id="role-name" class="role-name-large">Unknown</div>
      <p id="role-desc" class="role-desc"></p>
      <div id="role-instruction-box" class="instruction-box">
        <h4>Instructions</h4>
        <p id="role-instruction-text"></p>
      </div>
    </div>
    <!-- Mafia private chat (shown only to Mafia during night) -->
    <div id="mafia-night-chat" class="mafia-chat-panel hidden">
      <div class="mafia-chat-title">🔪 Mafia Private Chat</div>
      <div id="mafia-chat-messages"></div>
      <form class="mafia-chat-form" id="mafia-chat-form">
        <input type="text" id="mafia-chat-input" placeholder="Coordinate with your team..." autocomplete="off">
        <button type="submit">Send</button>
      </form>
    </div>
  </section>

  <!-- ── Night ── -->
  <section id="night-screen" class="screen text-center">
    <span class="phase-badge badge-blue">Night <span id="night-round">1</span></span>
    <h2 id="night-message">The village sleeps...</h2>
    <div id="timer-bar-night" class="timer-bar-container hidden">
      <div class="timer-label" id="timer-label-night">30s</div>
      <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-night" style="width:100%"></div></div>
    </div>
    <div id="night-step-indicator" class="steps">
      <div class="step-dot" data-step="mafia">Mafia</div>
      <div class="step-dot" data-step="doctor">Doctor</div>
      <div class="step-dot" data-step="cheikh">Cheikh</div>
    </div>
    <div id="night-waiting" style="padding:60px 0">
      <div class="big-emoji">😴</div>
      <p class="info-text">Close your eyes. Wait for your turn.</p>
    </div>
    <div id="night-action-panel" class="hidden">
      <p id="action-prompt" class="info-text" style="color:var(--text-primary);font-size:1.5rem"></p>
      <ul id="action-targets" class="target-list"></ul>
    </div>
    <div id="night-confirmed" class="hidden" style="padding:60px 0">
      <div class="big-emoji">✅</div>
      <p id="confirmed-message" style="color:var(--success);font-size:1.5rem;font-weight:700"></p>
    </div>
    <div id="cheikh-result-panel" class="hidden" style="padding:60px 0">
      <div class="big-emoji">👁️</div>
      <h3 style="margin:24px 0 16px;font-size:2rem">Investigation Result</h3>
      <p id="cheikh-result-text" style="font-size:1.5rem;font-weight:800"></p>
    </div>
    <!-- Mafia chat shown during night for Mafia role -->
    <div id="mafia-night-chat-night" class="mafia-chat-panel hidden">
      <div class="mafia-chat-title">🔪 Mafia Private Chat</div>
      <div id="mafia-chat-messages-night"></div>
      <form class="mafia-chat-form" id="mafia-chat-form-night">
        <input type="text" id="mafia-chat-input-night" placeholder="Coordinate with your team..." autocomplete="off">
        <button type="submit">Send</button>
      </form>
    </div>
  </section>

  <!-- ── Night Result / Dawn ── -->
  <section id="night-result-screen" class="screen text-center">
    <span class="phase-badge badge-yellow">Dawn</span>
    <h2>Morning Arrives</h2>
    <div class="big-emoji">🌅</div>
    <p id="night-result-message" class="info-text" style="font-size:1.5rem"></p>
    <div id="night-victim-info" class="result-card-large hidden">
      <span class="victim-label">Eliminated in the night</span>
      <div id="night-victim-name" class="victim-name"></div>
      <div id="night-victim-role" class="role-pill"></div>
    </div>
    <div id="last-words-display-night" class="last-words-display hidden"></div>
    <!-- Last words input (shown only to eliminated player) -->
    <div id="last-words-input-panel" class="hidden" style="max-width:500px;margin:0 auto">
      <div class="defense-card">
        <h3>💬 Your Last Words</h3>
        <p style="color:var(--text-secondary);margin-bottom:12px">You have been eliminated. Say something to the village!</p>
        <div id="timer-bar-lastwords" class="timer-bar-container">
          <div class="timer-label" id="timer-label-lastwords">15s</div>
          <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-lastwords" style="width:100%"></div></div>
        </div>
        <textarea class="defense-textarea" id="last-words-textarea" placeholder="Your last words..." maxlength="200"></textarea>
        <button id="btn-submit-last-words" class="btn btn-danger" style="max-width:200px">Submit</button>
      </div>
    </div>
  </section>

  <!-- ── Day ── -->
  <section id="day-screen" class="screen text-center">
    <span class="phase-badge badge-yellow">Day <span id="day-round">1</span></span>
    <h2>Discussion Time</h2>
    <div id="timer-bar-day" class="timer-bar-container">
      <div class="timer-label" id="timer-label-day">120s</div>
      <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-day" style="width:100%"></div></div>
    </div>
    <p class="info-text">Discuss among yourselves. Who is the Mafia?</p>
    <h4 style="color:var(--text-secondary);margin:20px 0;text-transform:uppercase;letter-spacing:0.1em">Alive Players</h4>
    <ul id="day-alive-list" class="player-list"></ul>
    <div id="day-host-controls" class="hidden" style="margin-top:40px">
      <button id="btn-move-to-vote" class="btn btn-danger" style="max-width:300px">Start Voting Now</button>
    </div>
    <p id="day-waiting-note" style="color:var(--text-muted);font-size:1.1rem;font-weight:500;margin-top:40px">Waiting for host to start voting...</p>
  </section>

  <!-- ── Vote ── -->
  <section id="vote-screen" class="screen text-center">
    <span class="phase-badge badge-red">Voting</span>
    <h2>Cast Your Vote</h2>
    <div id="timer-bar-vote" class="timer-bar-container">
      <div class="timer-label" id="timer-label-vote">30s</div>
      <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-vote" style="width:100%"></div></div>
    </div>
    <p id="vote-progress" style="font-size:1.2rem;font-weight:800;color:var(--accent);margin-bottom:24px">0 / 0 votes cast</p>
    <ul id="vote-targets" class="target-list"></ul>
    <div id="vote-submitted" class="hidden" style="padding:40px 0">
      <div class="big-emoji">🗳️</div>
      <p style="color:var(--success);font-size:1.5rem;font-weight:700">Vote cast. Waiting for others...</p>
    </div>
  </section>

  <!-- ── Defense ── -->
  <section id="defense-screen" class="screen text-center">
    <span class="phase-badge badge-yellow">Defense</span>
    <h2>Final Defense</h2>
    <div id="timer-bar-defense" class="timer-bar-container">
      <div class="timer-label" id="timer-label-defense">30s</div>
      <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-defense" style="width:100%"></div></div>
    </div>
    <div class="defense-card">
      <h3 id="defense-accused-name">Player</h3>
      <p style="color:var(--text-secondary)">has been accused. They have a chance to defend themselves.</p>
      <!-- Accused player sees this -->
      <div id="defense-input-area" class="hidden">
        <textarea class="defense-textarea" id="defense-textarea" placeholder="Say something to save yourself..." maxlength="300"></textarea>
        <button id="btn-submit-defense" class="btn" style="max-width:220px">Submit Defense</button>
      </div>
      <!-- Others see this -->
      <div id="defense-waiting-area">
        <div class="big-emoji" style="font-size:3rem">⏳</div>
        <p style="color:var(--text-secondary);font-weight:500">Waiting for their defense...</p>
      </div>
    </div>
  </section>

  <!-- ── Re-vote ── -->
  <section id="revote-screen" class="screen text-center">
    <span class="phase-badge badge-red">Final Vote</span>
    <h2>Eliminate or Spare?</h2>
    <div id="timer-bar-revote" class="timer-bar-container">
      <div class="timer-label" id="timer-label-revote">15s</div>
      <div class="timer-bar-bg"><div class="timer-bar-fill" id="timer-fill-revote" style="width:100%"></div></div>
    </div>
    <p id="revote-accused-label" style="font-size:1.3rem;font-weight:700;margin-bottom:16px"></p>
    <div id="revote-defense-text" class="defense-text-display hidden"></div>
    <p id="vote-progress-revote" style="font-size:1.1rem;font-weight:700;color:var(--accent);margin-bottom:16px">0 / 0 voted</p>
    <div id="revote-btns" class="revote-btns">
      <button id="btn-revote-yes" class="revote-btn yes">☠️ Eliminate</button>
      <button id="btn-revote-no" class="revote-btn no">🕊️ Spare</button>
    </div>
    <div id="revote-submitted" class="hidden" style="padding:24px 0">
      <div class="big-emoji">🗳️</div>
      <p style="color:var(--success);font-size:1.2rem;font-weight:700">Vote cast. Waiting for others...</p>
    </div>
    <div id="revote-accused-wait" class="hidden" style="padding:24px 0">
      <p style="color:var(--text-muted);font-size:1.1rem;font-weight:500">You cannot vote on your own fate.</p>
    </div>
  </section>

  <!-- ── Vote Result ── -->
  <section id="vote-result-screen" class="screen text-center">
    <span class="phase-badge badge-red">Result</span>
    <h2>Voting Finished</h2>
    <p id="vote-result-message" class="info-text" style="font-size:1.5rem"></p>
    <div id="vote-tally" class="tally-container"></div>
    <div id="vote-victim-info" class="result-card-large hidden">
      <span class="victim-label">Voted out by the village</span>
      <div id="vote-victim-name" class="victim-name"></div>
      <div id="vote-victim-role" class="role-pill"></div>
    </div>
    <div id="last-words-display-vote" class="last-words-display hidden"></div>
  </section>

  <!-- ── Game Over ── -->
  <section id="gameover-screen" class="screen text-center">
    <span id="gameover-badge" class="phase-badge">Game Over</span>
    <h2 id="gameover-title">Game Finished</h2>
    <div id="gameover-emoji" class="big-emoji" style="font-size:100px">🏆</div>
    <p id="gameover-message" class="info-text" style="font-size:1.5rem;color:var(--text-primary);font-weight:700"></p>
    <h4 style="color:var(--text-secondary);margin:40px 0 20px;text-transform:uppercase;letter-spacing:0.1em">Final Roles Revealed</h4>
    <ul id="gameover-players" class="player-list"></ul>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:40px">
      <button id="btn-play-again" class="btn hidden" style="max-width:220px">▶ Play Again</button>
      <button id="btn-back-lobby" class="btn btn-secondary" style="max-width:220px">🚪 Leave Room</button>
    </div>
    <p id="play-again-note" style="color:var(--text-muted);font-size:0.9rem;margin-top:12px">Waiting for host to decide...</p>
  </section>

  </div><!-- End app-container -->

  <!-- ── Chat Sidebar ── -->
  <aside id="chat-sidebar" class="chat-sidebar hidden">
    <div class="chat-header">💬 Room Chat</div>
    <div id="chat-messages" class="chat-messages">
      <div style="text-align:center;color:var(--text-muted);font-size:0.85rem;margin-top:20px">Welcome to the chat!</div>
    </div>
    <form id="chat-form" class="chat-form">
      <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off">
      <button type="submit" class="btn-send">Send</button>
    </form>
  </aside>

</div><!-- End layout-wrapper -->

<!-- Game Log -->
<button class="game-log-toggle hidden" id="btn-game-log" title="Game Log">📜</button>
<div class="game-log-panel hidden" id="game-log-panel">
  <div class="log-header">📜 Game Log</div>
  <div class="log-entries" id="log-entries"></div>
</div>

<div id="toast-container" class="toast-container"></div>

<script src="/socket.io/socket.io.js"></script>
<script src="/sounds.js"></script>
<script src="/game.js"></script>
</body>
</html>
